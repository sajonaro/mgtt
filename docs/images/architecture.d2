# mgtt — architecture diagram.
# Source of truth. Render with:
#   d2 docs/images/architecture.d2 docs/images/architecture.svg

vars: {
  d2-config: {
    layout-engine: elk
    pad: 20
  }
}

direction: down

# ---- operators (row 1) -----------------------------------------------
human: "human operator"
agent: "LLM agent (Claude Code, CI bot)"

# ---- mgtt core (row 2) -----------------------------------------------
mgtt: "mgtt core — pure reasoning, no backend credentials" {
  model: "model.yaml" { shape: cylinder }
  scens: "scenarios.yaml" { shape: cylinder }
  state: "incident state" { shape: cylinder }
  cli: "CLI"
  mcp: "MCP server"
  engine: "constraint engine\nwalk · rank · eliminate"

  cli -> engine
  mcp -> engine
  model -> engine
  scens -> engine: "simulate mode" { style.stroke-dash: 3 }
  engine -> state
}

# ---- adapters + registry (row 3) -------------------------------------
adapters: "adapters — hold the backend credentials" {
  k8s: "kubernetes"
  aws: "aws"
  docker: "docker"
  terraform: "terraform"
  tempo: "tempo"
  quickwit: "quickwit"
}

registry: "registry" {
  remote: "registry.yaml\n(GitHub Pages)"
  local: |md
    `$MGTT_HOME/providers/`
  |
  remote -> local: "mgtt provider install"
}

# ---- system under test (row 4) ---------------------------------------
sut: "system under test — your production · never touched by mgtt core" {
  nginx: "nginx"
  api: "api replicas"
  redis: "redis"
  queue: "kafka / sqs"
  rds: "postgres / rds" { shape: cylinder }
  tracing: "tempo + quickwit"

  nginx -> api
  api -> rds
  api -> redis
  api -> queue
  api -> tracing: "spans" { style.stroke-dash: 3 }
}

# ---- cross-tier flows ------------------------------------------------
human -> mgtt.cli
agent -> mgtt.mcp

mgtt.engine -> adapters: "probe request" { style.stroke-width: 2 }
adapters -> mgtt.engine: "parsed facts" { style.stroke-width: 2 }
adapters -> sut: "shell / SDK" { style.stroke-width: 2 }
sut -> adapters: "stdout / JSON" { style.stroke-width: 2 }

registry.local -> adapters: "loaded at startup" { style.stroke-dash: 3 }
